# REQUIRED: Gemini API key for poem analysis, OCR, scene breakdown, and Pulavar chat.
# Get one from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=paste_your_google_ai_studio_gemini_api_key_here

# OPTIONAL: Image generation backend.
# Use "placeholder" for no paid image API, "stability" for Stability AI, or "dalle" for OpenAI image generation.
IMAGE_BACKEND=placeholder

# OPTIONAL: Stability AI key, only needed when IMAGE_BACKEND=stability.
# Get one from Stability AI account settings.
STABILITY_API_KEY=paste_your_stability_ai_key_here

# OPTIONAL: OpenAI key, only needed when IMAGE_BACKEND=dalle or TTS_BACKEND=openai.
# Get one from the OpenAI dashboard: https://platform.openai.com/api-keys
OPENAI_API_KEY=paste_your_openai_api_key_here

# OPTIONAL: Hugging Face token, only needed for Hugging Face-backed features.
# Get one from Hugging Face settings: https://huggingface.co/settings/tokens
HF_TOKEN=paste_your_huggingface_token_here

# OPTIONAL: Text-to-speech backend.
# Use "gtts" for free Google Translate TTS, "elevenlabs" for ElevenLabs, or "openai" for OpenAI TTS.
TTS_BACKEND=gtts

# OPTIONAL: ElevenLabs settings, only needed when TTS_BACKEND=elevenlabs.
# Get the API key from ElevenLabs profile settings and the voice ID from your selected voice.
ELEVENLABS_API_KEY=paste_your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=paste_your_elevenlabs_voice_id_here
